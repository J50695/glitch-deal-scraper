# ============================================================
#  GLITCH DEAL SCRAPER â Environment Variables
#  Copy this to .env and fill in your values
#  On Railway: add these in the Variables tab
# ============================================================

# --- DISCORD (main alert channel) ---
# How to get: Server Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# --- KEEPA API (Amazon price history â most important) ---
# Sign up free at: https://keepa.com/#!api
# Free plan: 100 tokens/day (enough for ~30 product checks)
KEEPA_API_KEY=your_keepa_api_key_here

# --- EMAIL DIGEST (optional, for daily summaries) ---
# Use Gmail + an App Password (NOT your regular password)
# Generate App Password: myaccount.google.com/apppasswords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_TO=youremail@gmail.com

# --- SCRAPER SETTINGS ---
# Minimum % drop from normal price to trigger an alert (default: 70)
MIN_DISCOUNT_PCT=70

# How often to scrape, in minutes (default: 10)
# Lower = faster detection but higher risk of being rate-limited
SCRAPE_INTERVAL_MINUTES=10

# Max concurrent browser pages (default: 3, lower on cheap VPS)
MAX_CONCURRENT_PAGES=3

# --- SERVER ---
PORT=3000
